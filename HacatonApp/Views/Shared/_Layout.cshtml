<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Хакатон</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white py-3 border-bottom">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <span>🚀</span>
                    <span>Хакатон</span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav mx-auto gap-lg-1">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Главная</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Projects" asp-action="Index">Проекты</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Teams" asp-action="Index">Команды</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Results" asp-action="Index">Лидерборд</a></li>

                        @if (User.IsInRole("Jury") || User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Jury" asp-action="Index">Оценка проектов</a></li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Администрирование</a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">Панель администратора</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">Пользователи</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Zaiavki">Заявки жюри</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="TeamZaiavki">Заявки команд</a></li>
                                    <li><a class="dropdown-item" asp-controller="Criteria" asp-action="Index">Конструктор критериев</a></li>
                                </ul>
                            </li>
                        }

                        @if (!User.IsInRole("Jury") && !User.IsInRole("Admin") && !User.IsInRole("Teamer") && User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Jury" asp-action="SubmitZaiavka">Стать судьёй</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Team" asp-action="SubmitTeamZaiavka">Создать команду</a></li>
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1">
        <div class="container pt-4">
            @if (TempData["SuccessMessage"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @successMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @errorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>

        @RenderBody()
    </main>

    <footer class="footer mt-auto border-top bg-white">
        <div class="container py-4">
            <div class="row align-items-center g-3">
                <div class="col-md-4 text-center text-md-start">
                    <div class="fw-bold">🚀 Хакатон</div>
                    <div class="text-secondary small">Платформа для команд, жюри и прозрачного лидерборда.</div>
                </div>
                <div class="col-md-4 text-center">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-secondary">Главная</a>
                    <span class="mx-2 text-secondary">•</span>
                    <a asp-controller="Projects" asp-action="Index" class="text-decoration-none text-secondary">Проекты</a>
                    <span class="mx-2 text-secondary">•</span>
                    <a asp-controller="Teams" asp-action="Index" class="text-decoration-none text-secondary">Команды</a>
                    <span class="mx-2 text-secondary">•</span>
                    <a asp-controller="Results" asp-action="Index" class="text-decoration-none text-secondary">Лидерборд</a>
                </div>
                <div class="col-md-4 text-center text-md-end text-secondary small">
                    &copy; @DateTime.Now.Year Хакатон
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
