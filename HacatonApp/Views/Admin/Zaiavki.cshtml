@model List<JuryZaiavka>
@{
    ViewData["Title"] = "Заявки в жюри";
}

<div class="container mt-4">
    <h2>Заявки в жюри</h2>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }
    
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Имя</th>
                <th>Email</th>
                <th>Статус</th>
                <th>Дата подачи</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var zaiavka in Model)
            {
                <tr>
                    <td>@zaiavka.Id</td>
                    <td>@zaiavka.FullName</td>
                    <td>@zaiavka.ContactEmail</td>
                    <td>
                        @if (zaiavka.Status == "Wait")
                        {
                            <span class="badge bg-warning">На рассмотрении</span>
                        }
                        else if (zaiavka.Status == "Accepted")
                        {
                            <span class="badge bg-success">Одобрена</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Отклонена</span>
                        }
                    </td>
                    <td>@zaiavka.SubmitedAt.ToString("dd.MM.yyyy")</td>
                    <td>
                        <a asp-action="CheckZaiavka" asp-route-id="@zaiavka.Id" class="btn btn-sm btn-info">Просмотр</a>
                        @if (zaiavka.Status == "Wait")
                        {
                            <form asp-action="KrutiZaiavky" method="post" style="display:inline">
                                <input type="hidden" name="id" value="@zaiavka.Id" />
                                <button type="submit" class="btn btn-sm btn-success">Одобрить</button>
                            </form>
                            <form asp-action="PlohoZaiavky" method="post" style="display:inline">
                                <input type="hidden" name="id" value="@zaiavka.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Отклонить</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>