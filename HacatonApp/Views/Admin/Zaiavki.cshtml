@model List<JuryZaiavkaViewModel>
@{
    ViewData["Title"] = "Пользователи";
}

<h2>Управление пользователями</h2>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Email</th>
            <th>Имя</th>
            <th>Фамилия</th>
            <th>Роли</th>
            <th>Действия</th>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FirstName</td>
                <td>@user.LastName</td>
                <td>@user.Motivation</td>
                <td>@user.ContactEmail</td>
                <tr>
                    <a asp-action="CheckZaiavka" asp-route-id="@user.ZaiavkaId" class="btn btn-warning btn-sm">
                        Перейти к рассмотру
                    </a>
                </tr>
                
            </tr>
        }
    </tbody>
</table>