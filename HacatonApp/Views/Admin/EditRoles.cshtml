@model EditUserRoleViewModel
@{
    ViewData["Title"] = "Редактирование ролей";
}

<div class="container py-5 page-container-narrow">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-2">Редактирование ролей</h1>
            <p class="text-secondary mb-0">Пользователь: <strong>@Model.FullName</strong> · <strong>@Model.Email</strong></p>
        </div>
        <a asp-action="Users" class="btn btn-outline-secondary">Назад к пользователям</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4 p-lg-5">
            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserId" />

                <div class="d-grid gap-3">
                    @for (int i = 0; i < Model.Roles.Count; i++)
                    {
                        <label class="member-option mb-0">
                            <input type="hidden" asp-for="@Model.Roles[i].RoleName" />
                            <input class="form-check-input flex-shrink-0 mt-1" type="checkbox" asp-for="@Model.Roles[i].IsSelected" />
                            <span>
                                <span class="fw-semibold d-block">@Model.Roles[i].RoleName</span>
                                <span class="text-secondary small">Предоставляет доступ к соответствующему разделу платформы.</span>
                            </span>
                        </label>
                    }
                </div>

                <div class="d-flex flex-wrap gap-3 mt-4 page-actions">
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                    <a asp-action="Users" class="btn btn-outline-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>
