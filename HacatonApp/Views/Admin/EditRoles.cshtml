@model EditUserRoleViewModel
@{
    ViewData["Title"] = "Редактирование ролей";
}

<h2>Редактирование ролей для @Model.FullName</h2>
<p>Email: @Model.Email</p>

<form method="post">
    <input type="hidden" asp-for="UserId" />

    @for (int i = 0; i < Model.Roles.Count; i++)
    {
        <div class="form-check mb-2">
            <input type="hidden" asp-for="@Model.Roles[i].RoleName" />
            <input class="form-check-input" type="checkbox" asp-for="@Model.Roles[i].IsSelected" />
            <label class="form-check-label">@Model.Roles[i].RoleName</label>
        </div>
    }

    <button type="submit" class="btn btn-primary mt-3">Сохранить</button>
    <a asp-action="Users" class="btn btn-secondary mt-3">Назад</a>
</form>