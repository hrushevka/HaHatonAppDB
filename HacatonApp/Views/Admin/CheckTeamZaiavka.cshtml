@model TeamZaiavkaViewModel
@{
    ViewData["Title"] = "Проверка заявки команды";
}

<div class="container py-5" style="max-width: 960px;">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-2">Проверка заявки команды</h1>
            <p class="text-secondary mb-0">Команда <strong>@Model.TeamName</strong> — проект <strong>@Model.ProjectName</strong>.</p>
        </div>
        <a asp-action="TeamZaiavki" class="btn btn-outline-secondary">Назад к списку</a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="text-secondary small mb-1">Капитан</div>
                    <div class="fw-semibold">@Model.CaptainName</div>
                </div>
                <div class="col-md-6">
                    <div class="text-secondary small mb-1">Контактный email</div>
                    <div class="fw-semibold">@Model.ContactEmail</div>
                </div>
                <div class="col-12">
                    <div class="text-secondary small mb-1">Описание проекта</div>
                    <div>@Model.ProjectDescription</div>
                </div>
                <div class="col-12">
                    <div class="text-secondary small mb-1">Мотивация</div>
                    <div>@(string.IsNullOrWhiteSpace(Model.Motivation) ? "Не указана" : Model.Motivation)</div>
                </div>
                <div class="col-12">
                    <div class="text-secondary small mb-2">Участники</div>
                    @if (Model.TeamMemberNames.Any())
                    {
                        <ul class="list-group list-group-flush border rounded-3">
                            @foreach (var memberName in Model.TeamMemberNames)
                            {
                                <li class="list-group-item">@memberName</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-secondary">Дополнительные участники не указаны.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (Model.Status == "Wait")
    {
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card border-success border-2 h-100">
                    <div class="card-body p-4">
                        <h2 class="h4 fw-bold text-success mb-3">Одобрить заявку</h2>
                        <form asp-action="AcceptTeamZaiavka" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.ZaiavkaId" />
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Комментарий администратора</label>
                                <textarea name="adminComment" class="form-control" rows="4" placeholder="Например: Команда принята в основной трек"></textarea>
                            </div>
                            <button type="submit" class="btn btn-success w-100">Одобрить</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-danger border-2 h-100">
                    <div class="card-body p-4">
                        <h2 class="h4 fw-bold text-danger mb-3">Отклонить заявку</h2>
                        <form asp-action="RejectTeamZaiavka" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.ZaiavkaId" />
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Комментарий администратора</label>
                                <textarea name="adminComment" class="form-control" rows="4" placeholder="Например: Не хватает описания проекта"></textarea>
                            </div>
                            <button type="submit" class="btn btn-danger w-100">Отклонить</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        var badgeClass = Model.Status == "Accepted" ? "bg-success" : "bg-danger";
        <div class="alert alert-light border">
            <div class="d-flex flex-column gap-2">
                <div>
                    <span class="badge @badgeClass">@Model.Status</span>
                </div>
                <div>
                    <strong>Комментарий:</strong>
                    @(string.IsNullOrWhiteSpace(Model.AdminComment) ? "не указан" : Model.AdminComment)
                </div>
            </div>
        </div>
    }
</div>
