@model JuryZaiavkaViewModel
@{
    ViewData["Title"] = "Рассмотр заявки на судью";
}

<div class="container py-5 page-container-wide">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-2">Рассмотр заявки на судью</h1>
            <p class="text-secondary mb-0">Кандидат: <strong>@Model.FirstName @Model.LastName</strong>. Связь: <strong>@Model.ContactEmail</strong>.</p>
        </div>
        <a asp-action="Zaiavki" class="btn btn-outline-secondary">Назад к списку</a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="text-secondary small mb-1">Имя</div>
                    <div class="fw-semibold">@Model.FirstName</div>
                </div>
                <div class="col-md-6">
                    <div class="text-secondary small mb-1">Фамилия</div>
                    <div class="fw-semibold">@Model.LastName</div>
                </div>
                <div class="col-12">
                    <div class="text-secondary small mb-1">Email</div>
                    <div class="fw-semibold">@Model.ContactEmail</div>
                </div>
                <div class="col-12">
                    <div class="text-secondary small mb-1">Мотивация</div>
                    <div>@Model.Motivation</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-success border-2 h-100">
                <div class="card-body p-4">
                    <h2 class="h4 fw-bold text-success mb-3">Одобрить заявку</h2>
                    <form asp-action="KrutiZaiavky" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.ZaiavkaId" />
                        <div class="mb-3">
                            <label class="form-label">Комментарий администратора</label>
                            <textarea name="adminComment" class="form-control" rows="4" placeholder="Например: Отличный релевантный опыт для жюри"></textarea>
                        </div>
                        <button type="submit" class="btn btn-success w-100">Одобрить заявку</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-danger border-2 h-100">
                <div class="card-body p-4">
                    <h2 class="h4 fw-bold text-danger mb-3">Отклонить заявку</h2>
                    <form asp-action="PlohoZaiavky" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.ZaiavkaId" />
                        <div class="mb-3">
                            <label class="form-label">Комментарий администратора</label>
                            <textarea name="adminComment" class="form-control" rows="4" placeholder="Например: Сейчас не хватает подтверждённого опыта"></textarea>
                        </div>
                        <button type="submit" class="btn btn-danger w-100">Отклонить заявку</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
