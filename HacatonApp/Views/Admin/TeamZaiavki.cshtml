@model List<TeamZaiavkaViewModel>
@{
    ViewData["Title"] = "Заявки команд";
}

<div class="container py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-1">Заявки команд</h1>
            <p class="text-secondary mb-0">Просмотр, проверка и принятие командных заявок.</p>
        </div>
        <a asp-controller="Criteria" asp-action="Index" class="btn btn-outline-primary">Конструктор критериев</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Заявок команд пока нет.</div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Команда</th>
                            <th>Проект</th>
                            <th>Email</th>
                            <th>Статус</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var badgeClass = item.Status == "Accepted"
                                ? "bg-success"
                                : item.Status == "Denied"
                                    ? "bg-danger"
                                    : "bg-warning text-dark";

                            <tr>
                                <td class="fw-semibold">@item.TeamName</td>
                                <td>@item.ProjectName</td>
                                <td>@item.ContactEmail</td>
                                <td><span class="badge @badgeClass">@item.Status</span></td>
                                <td class="text-end">
                                    <a asp-action="CheckTeamZaiavka" asp-route-id="@item.ZaiavkaId" class="btn btn-sm btn-primary">Открыть</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
