@model List<TeamZaiavkaViewModel>
@{
    ViewData["Title"] = "Заявки команд";
}

<h2>Управление заявками команд</h2>
<table class="table table-striped table-bordered">
    <thead>
        <tr><th>Команда</th><th>Проект</th><th>Email</th><th>Действия</th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr><td>@item.TeamName</td><td>@item.ProjectName</td><td>@item.ContactEmail</td>
            <td><a asp-action="CheckTeamZaiavka" asp-route-id="@item.ZaiavkaId" class="btn btn-warning btn-sm">Рассмотреть</a></td></tr>
        }
    </tbody>
</table>