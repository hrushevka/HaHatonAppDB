@model List<UserWithRolesViewModel>
@{
    ViewData["Title"] = "Пользователи";
}

<div class="container py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-2">Пользователи</h1>
            <p class="text-secondary mb-0">Список зарегистрированных пользователей и назначенных им ролей.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад в админ панель</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Пользователи пока не найдены.</div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 table-stack">
                    <thead class="table-light">
                        <tr>
                            <th>Email</th>
                            <th>Имя</th>
                            <th>Фамилия</th>
                            <th>Роли</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td data-label="Email">@user.Email</td>
                                <td data-label="Имя">@user.FirstName</td>
                                <td data-label="Фамилия">@user.LastName</td>
                                <td data-label="Роли">
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var role in user.Roles)
                                        {
                                            <span class="badge bg-primary">@role</span>
                                        }
                                    </div>
                                </td>
                                <td data-label="Действия" class="text-end">
                                    <a asp-action="EditRoles" asp-route-id="@user.UserId" class="btn btn-warning btn-sm">Редактировать роли</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
