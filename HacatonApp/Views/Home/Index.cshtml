@{
    ViewData["Title"] = "Хакатон";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<style>
    .hero-card {
        border: 0;
        border-radius: 24px;
        background: linear-gradient(135deg, #f4f8ff, #ffffff);
        box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
    }
    .feature-card {
        border: 0;
        border-radius: 20px;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .feature-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 32px rgba(15, 23, 42, 0.1);
    }
    .feature-icon {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        background: #e8f0fe;
        color: #1a73e8;
        margin-bottom: 1rem;
    }
</style>

<div class="container py-5">
    <div class="hero-card p-4 p-lg-5 mb-5">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <div class="display-6 fw-bold mb-3">Платформа хакатона для команд, жюри и администраторов</div>
                <p class="lead text-secondary mb-4">
                    Собирайте команды до 5 человек, отправляйте проекты, создавайте критерии оценки,
                    выставляйте баллы по критериям и следите за лидербордом в реальном времени.
                </p>

                <div class="d-flex flex-wrap gap-3">
                    @if (!isAuthenticated)
                    {
                        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg px-4">Регистрация</a>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-lg px-4">Вход</a>
                        <a asp-controller="Results" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Лидерборд</a>
                    }
                    else if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Index" class="btn btn-primary btn-lg px-4">Админ панель</a>
                        <a asp-controller="Criteria" asp-action="Index" class="btn btn-outline-primary btn-lg px-4">Критерии</a>
                        <a asp-controller="Results" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Лидерборд</a>
                    }
                    else if (User.IsInRole("Jury"))
                    {
                        <a asp-controller="Jury" asp-action="Index" class="btn btn-primary btn-lg px-4">Оценивать проекты</a>
                        <a asp-controller="Results" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Лидерборд</a>
                    }
                    else if (User.IsInRole("Teamer"))
                    {
                        <a asp-controller="Teams" asp-action="Index" class="btn btn-primary btn-lg px-4">Команды</a>
                        <a asp-controller="Projects" asp-action="Index" class="btn btn-outline-primary btn-lg px-4">Проекты</a>
                        <a asp-controller="Results" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Лидерборд</a>
                    }
                    else
                    {
                        <a asp-controller="Team" asp-action="SubmitTeamZaiavka" class="btn btn-primary btn-lg px-4">Создать команду</a>
                        <a asp-controller="Jury" asp-action="SubmitZaiavka" class="btn btn-outline-primary btn-lg px-4">Стать судьёй</a>
                        <a asp-controller="Results" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Лидерборд</a>
                    }
                </div>
            </div>
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="small text-secondary mb-2">Что уже поддерживается</div>
                        <ul class="mb-0 ps-3">
                            <li>Заявки команд с выбором участников</li>
                            <li>Конструктор критериев у администратора</li>
                            <li>Оценка проектов судьями с комментариями</li>
                            <li>Автоматический подсчёт среднего балла</li>
                            <li>Публичный лидерборд проектов</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card feature-card h-100 p-4">
                <div class="feature-icon">👥</div>
                <h2 class="h4 fw-bold">Команды</h2>
                <p class="text-secondary mb-0">Собирайте команду до 5 человек, отправляйте заявку и публикуйте проект после одобрения.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card feature-card h-100 p-4">
                <div class="feature-icon">🧑‍⚖️</div>
                <h2 class="h4 fw-bold">Жюри</h2>
                <p class="text-secondary mb-0">Оценивайте проекты по заданным критериям, выставляйте баллы и оставляйте комментарии к проекту.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card feature-card h-100 p-4">
                <div class="feature-icon">🏆</div>
                <h2 class="h4 fw-bold">Итоги</h2>
                <p class="text-secondary mb-0">Следите за средним баллом каждого проекта и финальным рейтингом на отдельной странице результатов.</p>
            </div>
        </div>
    </div>
</div>
