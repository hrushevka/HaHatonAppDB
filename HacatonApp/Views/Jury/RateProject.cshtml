@using System.Globalization
@model RateProjectViewModel
@{
    ViewData["Title"] = "Оценка проекта";
}

<div class="container py-5 page-container-wide">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <div class="text-secondary small mb-1">Команда: @Model.TeamName</div>
            <h1 class="display-6 fw-bold mb-2">@Model.ProjectName</h1>
            <p class="text-secondary mb-0">@Model.ProjectDescription</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Назад к списку</a>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="text-secondary small mb-1">Текущий средний балл</div>
                    <div class="display-6 fw-bold">@Model.CurrentAverageScore.ToString("0.##") / 100</div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="text-secondary small mb-1">Количество оценок</div>
                    <div class="display-6 fw-bold">@Model.ReviewsCount</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4 p-lg-5">
            <form asp-action="RateProject" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="ProjectId" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                @for (var i = 0; i < Model.CriteriaScores.Count; i++)
                {
                    <input asp-for="CriteriaScores[i].CriteriaId" type="hidden" />
                    <input asp-for="CriteriaScores[i].CriteriaName" type="hidden" />
                    <input asp-for="CriteriaScores[i].Weight" type="hidden" />
                    <input asp-for="CriteriaScores[i].MaxScore" type="hidden" />

                    <div class="card mb-3 border-light bg-light-subtle">
                        <div class="card-body">
                            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                                <div>
                                    <h2 class="h5 fw-bold mb-1">@Model.CriteriaScores[i].CriteriaName</h2>
                                    <div class="text-secondary small">
                                        Максимум: @Model.CriteriaScores[i].MaxScore.ToString("0.##") • Вес: @Model.CriteriaScores[i].Weight.ToString("0.##")
                                    </div>
                                </div>
                                <div class="criteria-score-input">
                                    <label asp-for="CriteriaScores[i].Score" class="form-label fw-semibold mb-1">Балл</label>
                                    <input asp-for="CriteriaScores[i].Score"
                                           class="form-control text-end"
                                           type="number"
                                           min="0"
                                           max="@Model.CriteriaScores[i].MaxScore.ToString(CultureInfo.InvariantCulture)"
                                           step="0.1" />
                                    <span asp-validation-for="CriteriaScores[i].Score" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="mt-4">
                    <label asp-for="Comment" class="form-label fw-semibold">Комментарий судьи</label>
                    <textarea asp-for="Comment" rows="6" class="form-control" placeholder="Опишите сильные стороны проекта, рекомендации и замечания"></textarea>
                    <span asp-validation-for="Comment" class="text-danger small"></span>
                </div>

                <div class="d-flex flex-wrap gap-3 mt-4 page-actions">
                    <button type="submit" class="btn btn-primary btn-lg px-4">Сохранить оценку</button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
