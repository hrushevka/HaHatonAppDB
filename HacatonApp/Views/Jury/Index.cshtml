@model List<JuryProjectListItemViewModel>
@{
    ViewData["Title"] = "Оценка проектов";
}

<div class="container py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h1 class="display-6 fw-bold mb-2">Оценка проектов</h1>
            <p class="text-secondary mb-0">Выставляйте баллы по критериям, добавляйте комментарии и влияйте на общий рейтинг.</p>
        </div>
        <a asp-controller="Results" asp-action="Index" class="btn btn-outline-primary">Открыть лидерборд</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Пока нет проектов для оценки.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                var badgeClass = item.IsRatedByCurrentUser ? "bg-success" : "bg-secondary";
                <div class="col-lg-6">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body p-4 d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <div class="text-secondary small mb-1">Команда: @item.TeamName</div>
                                    <h2 class="h4 fw-bold mb-0">@item.ProjectName</h2>
                                </div>
                                <span class="badge @badgeClass">@(item.IsRatedByCurrentUser ? "Оценён вами" : "Ждёт оценку")</span>
                            </div>

                            <p class="text-secondary flex-grow-1">@item.ProjectDescription</p>

                            <div class="d-flex gap-4 mb-4">
                                <div>
                                    <div class="small text-secondary">Средний балл</div>
                                    <div class="fw-bold">@item.AverageScore.ToString("0.##") / 100</div>
                                </div>
                                <div>
                                    <div class="small text-secondary">Оценок</div>
                                    <div class="fw-bold">@item.ReviewsCount</div>
                                </div>
                            </div>

                            <a asp-action="RateProject" asp-route-id="@item.ProjectId" class="btn btn-primary w-100">
                                @(item.IsRatedByCurrentUser ? "Изменить оценку" : "Оценить проект")
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
