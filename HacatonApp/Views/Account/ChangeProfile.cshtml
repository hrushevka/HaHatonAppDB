@model ChangeProfileViewModel
@{
    ViewData["Title"] = "Профиль";
}

<div class="container py-5 page-container-narrow">
    <div class="text-center mb-4">
        <h1 class="display-6 fw-bold mb-2">Профиль</h1>
        <p class="text-secondary mb-0">Обновите личные данные и сохраните актуальную информацию профиля.</p>
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h2 class="h4 mb-0">Редактирование профиля</h2>
        </div>
        <div class="card-body">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input asp-for="Id" type="hidden" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" readonly />
                </div>

                <div class="d-flex flex-wrap gap-3 mt-4 page-actions">
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                    <a asp-controller="Account" asp-action="ChangePassword" class="btn btn-outline-secondary">Сменить пароль</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
