@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Смена пароля";
}

<div class="container py-5 page-container-narrow">
    <div class="text-center mb-4">
        <h1 class="display-6 fw-bold mb-2">Смена пароля</h1>
        <p class="text-secondary mb-0">Обновите пароль для безопасного входа в систему.</p>
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-warning">
            <h2 class="h4 mb-0">Новый пароль</h2>
        </div>
        <div class="card-body">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="OldPassword" class="form-label"></label>
                    <input asp-for="OldPassword" type="password" class="form-control" />
                    <span asp-validation-for="OldPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" type="password" class="form-control" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewConfirmPassword" class="form-label"></label>
                    <input asp-for="NewConfirmPassword" type="password" class="form-control" />
                    <span asp-validation-for="NewConfirmPassword" class="text-danger"></span>
                </div>

                <div class="d-flex flex-wrap gap-3 page-actions">
                    <button type="submit" class="btn btn-warning">Сменить пароль</button>
                    <a asp-controller="Account" asp-action="ChangeProfile" class="btn btn-outline-secondary">Назад к профилю</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
